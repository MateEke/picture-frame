---
// Brand lockup: amber picture mark + wordmark in the Fraunces display face,
// so the header matches the landing.
import { Icon } from 'astro-icon/components';
const { siteTitle, siteTitleHref } = Astro.locals.starlightRoute;
---

<a href={siteTitleHref} class="site-title sl-flex">
	<Icon name="lucide:image" class="pf-logo" />
	<span class="pf-sitetitle" translate="no">{siteTitle}</span>
</a>

<style>
	.site-title {
		align-items: center;
		gap: 0.55rem;
		text-decoration: none;
		white-space: nowrap;
		min-width: 0;
	}
	.pf-logo {
		flex: none;
		width: 1.55rem;
		height: 1.55rem;
		color: var(--pf-amber);
	}
	.pf-sitetitle {
		font-family: var(--pf-display);
		font-weight: 600;
		font-size: var(--sl-text-h4);
		letter-spacing: -0.01em;
		color: var(--sl-color-white);
		overflow: hidden;
	}
</style>
