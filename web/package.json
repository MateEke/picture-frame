{
	"name": "web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && tsc --noEmit -p e2e",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint --no-warn-ignored .",
		"lint:fix": "prettier --write . && eslint --no-warn-ignored --fix .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test --project=chromium",
		"test:e2e:headed": "playwright test --project=chromium --headed",
		"test:e2e:ui": "playwright test --project=chromium --ui",
		"test:e2e:all": "playwright test",
		"test:mutation": "stryker run && stryker run stryker.client.config.json",
		"test:mutation:ci": "stryker run --incremental && stryker run --incremental stryker.client.config.json",
		"test:mutation:server": "stryker run",
		"test:mutation:client": "stryker run stryker.client.config.json"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@hey-api/openapi-ts": "^0.99.0",
		"@hey-api/vite-plugin": "^0.3.2",
		"@playwright/test": "^1.61.1",
		"@skeletonlabs/skeleton": "^4.15.2",
		"@skeletonlabs/skeleton-svelte": "^4.15.2",
		"@stryker-mutator/core": "^9.6.1",
		"@stryker-mutator/vitest-runner": "^9.6.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.68.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/vite": "^4.3.1",
		"@types/node": "^26",
		"@vitest/browser-playwright": "^4.1.9",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"playwright": "^1.59.1",
		"prettier": "^3.9.1",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"rollup-plugin-sbom": "^3.2.3",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.62.0",
		"vite": "^8.1.0",
		"vitest": "^4.1.3",
		"vitest-browser-svelte": "^2.1.0"
	},
	"dependencies": {
		"@fontsource-variable/schibsted-grotesk": "^5.2.8",
		"@fontsource/google-sans": "^5.2.1",
		"@lucide/svelte": "^1.21.0",
		"@meteocons/svg-static": "^0.1.0",
		"cropt": "^1.2.2",
		"svelte-dnd-action": "^0.9.70"
	}
}
